%%{init: {"theme": "default", "er": {"diagramPadding": 30, "layoutDirection": "TB", "minEntityWidth": 100, "minEntityHeight": 75, "entityPadding": 15, "useMaxWidth": true}}}%%
erDiagram
    BENEFICIARIOS {
        VARCHAR2_18 CURP PK
        VARCHAR2_100 NOMBRES
        VARCHAR2_100 APELLIDO_PATERNO
        VARCHAR2_100 APELLIDO_MATERNO
        DATE FECHA_NACIMIENTO
        VARCHAR2_20 GENERO
        VARCHAR2_10 ESTATUS
        VARCHAR2_50 TIPO_ESPINA_BIFIDA
        CHAR_1 USA_VALVULA
        VARCHAR2_1 TIPO_CUOTA
        DATE FECHA_ALTA
    }

    CREDENCIALES {
        NUMBER ID_CREDENCIAL PK
        VARCHAR2_18 CURP FK
        VARCHAR2_50 NUMERO_CREDENCIAL
        DATE FECHA_VIGENCIA_INICIO
        DATE FECHA_VIGENCIA_FIN
        DATE FECHA_ULTIMO_PAGO
        VARCHAR2_50 METODO_PAGO
        NUMBER_10_2 MONTO
        CLOB OBSERVACIONES
    }

    SERVICIOS {
        NUMBER ID_SERVICIO PK
        VARCHAR2_18 CURP FK
        NUMBER ID_TIPO_SERVICIO FK
        TIMESTAMP FECHA
        NUMBER_10_2 COSTO
        NUMBER_10_2 MONTO_PAGADO
        VARCHAR2_20 ESTATUS
        NUMBER REFERENCIA_ID
        VARCHAR2_50 REFERENCIA_TIPO
    }

    SERVICIO_ARTICULOS {
        NUMBER ID PK
        NUMBER ID_SERVICIO FK
        NUMBER ID_ARTICULO FK
        NUMBER CANTIDAD
    }

    ARTICULOS {
        NUMBER ID_ARTICULO PK
        NUMBER ID_CATEGORIA FK
        VARCHAR2_150 DESCRIPCION
        VARCHAR2_50 UNIDAD
        NUMBER_10_2 CUOTA_RECUPERACION
        NUMBER_10_2 CUOTA_B
        NUMBER INVENTARIO_ACTUAL
        NUMBER STOCK_MINIMO
        CHAR_1 MANEJA_INVENTARIO
        NUMBER_1 ACTIVO
    }

    CATEGORIAS_ARTICULO {
        NUMBER ID_CATEGORIA PK
        VARCHAR2_100 NOMBRE
    }

    MOVIMIENTOS_INVENTARIO {
        NUMBER ID_MOVIMIENTO PK
        NUMBER ID_ARTICULO FK
        VARCHAR2_50 TIPO_MOVIMIENTO
        NUMBER CANTIDAD
        DATE FECHA
        CLOB MOTIVO
    }

    COMODATOS {
        NUMBER ID_COMODATO PK
        VARCHAR2_18 CURP FK
        NUMBER ID_ARTICULO FK
        NUMBER_10_2 MONTO_TOTAL
        NUMBER_10_2 MONTO_PAGADO
        NUMBER_10_2 MONTO_EXENTO
        VARCHAR2_20 ESTATUS
        DATE FECHA_ALTA
        DATE FECHA_DEVOLUCION_ESPERADA
        DATE FECHA_DEVOLUCION_REAL
    }

    COMODATOS_PAGOS {
        NUMBER ID_PAGO PK
        NUMBER ID_COMODATO FK
        NUMBER_10_2 MONTO
        CHAR_1 ES_EXENTO
        DATE FECHA
    }

    CITAS {
        NUMBER ID_CITA PK
        VARCHAR2_18 CURP FK
        NUMBER ID_TIPO_SERVICIO FK
        VARCHAR2_100 ESPECIALISTA
        TIMESTAMP FECHA
        VARCHAR2_50 ESTATUS
        NUMBER DURACION_MINUTOS
    }

    SERVICIOS_CATALOGO {
        NUMBER ID_TIPO_SERVICIO PK
        VARCHAR2_100 NOMBRE
        VARCHAR2_20 TIPO_SERVICIO
        VARCHAR2_255 DESCRIPCION
    }

    PADECIMIENTOS {
        NUMBER ID_PADECIMIENTO PK
        VARCHAR2_150 NOMBRE
    }

    BENEFICIARIO_PADECIMIENTOS {
        VARCHAR2_18 CURP FK
        NUMBER ID_PADECIMIENTO FK
    }

    ESPECIALIDADES_HORARIO {
        NUMBER ID_ESPECIALIDAD PK
        VARCHAR2_100 NOMBRE
        NUMBER_1 DIA_SEMANA
        VARCHAR2_5 HORA_INICIO
        VARCHAR2_5 HORA_FIN
        NUMBER CAPACIDAD_MAX
        VARCHAR2_30 TIPO_FRECUENCIA
        NUMBER_1_0 ACTIVO
    }

    ESPECIALIDADES_EXCEPCIONES {
        NUMBER ID_EXCEPCION PK
        NUMBER ID_ESPECIALIDAD FK
        DATE FECHA
        VARCHAR2_500 MOTIVO
        TIMESTAMP CREATED_AT
    }

    ADMINISTRADORES {
        NUMBER ID_ADMIN PK
        NUMBER ID_ROL FK
        VARCHAR2_150 NOMBRE_COMPLETO
        VARCHAR2_100 EMAIL
        VARCHAR2_255 PASSWORD_HASH
        NUMBER_1 ACTIVO
        VARCHAR2_20 TELEFONO
        DATE FECHA_CREACION
    }

    ROLES {
        NUMBER ID_ROL PK
        VARCHAR2_50 NOMBRE_ROL
    }

    AUDITORIA_OPERACIONES {
        NUMBER ID_AUDITORIA PK
        NUMBER ID_ADMIN FK
        VARCHAR2_100 OPERACION
        VARCHAR2_100 ENTIDAD
        VARCHAR2_100 ENTIDAD_ID
        TIMESTAMP FECHA
        VARCHAR2_45 IP
    }

    REFRESH_TOKENS {
        NUMBER ID PK
        NUMBER ID_ADMIN FK
        VARCHAR2_500 TOKEN
        TIMESTAMP EXPIRES_AT
        TIMESTAMP CREATED_AT
    }

    NOTIFICACIONES {
        NUMBER ID_NOTIFICACION PK
        VARCHAR2_50 TIPO
        CLOB MENSAJE
        NUMBER_1 LEIDA
        TIMESTAMP FECHA_CREACION
    }

    BENEFICIARIOS ||--o{ CREDENCIALES : "tiene"
    BENEFICIARIOS ||--o{ SERVICIOS : "recibe"
    BENEFICIARIOS ||--o{ CITAS : "agenda"
    BENEFICIARIOS ||--o{ BENEFICIARIO_PADECIMIENTOS : "presenta"
    BENEFICIARIOS ||--o{ COMODATOS : "recibe_equipo"
    PADECIMIENTOS ||--o{ BENEFICIARIO_PADECIMIENTOS : "diagnosticado_en"
    SERVICIOS ||--o{ SERVICIO_ARTICULOS : "consume"
    ARTICULOS ||--o{ SERVICIO_ARTICULOS : "incluido_en"
    ARTICULOS ||--o{ MOVIMIENTOS_INVENTARIO : "registra"
    ARTICULOS }o--|| CATEGORIAS_ARTICULO : "pertenece_a"
    ARTICULOS ||--o{ COMODATOS : "prestado_en"
    COMODATOS ||--o{ COMODATOS_PAGOS : "recibe_pagos"
    SERVICIOS_CATALOGO ||--o{ SERVICIOS : "tipifica"
    SERVICIOS_CATALOGO ||--o{ CITAS : "tipifica"
    ROLES ||--o{ ADMINISTRADORES : "asigna"
    ADMINISTRADORES ||--o{ AUDITORIA_OPERACIONES : "genera"
    ADMINISTRADORES ||--o{ REFRESH_TOKENS : "posee"
    ESPECIALIDADES_HORARIO ||--o{ ESPECIALIDADES_EXCEPCIONES : "tiene_excepcion"
