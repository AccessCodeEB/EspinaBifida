# Copia este archivo como .env.local y ajusta los valores
# Debe apuntar al backend Express (no al puerto de Next), p. ej. 3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Cloudflare Turnstile — clave pública del widget (misma que en el dashboard de Turnstile).
# Sin ella en desarrollo se usa una clave de prueba (aviso «solo pruebas» y desafío de prueba).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
