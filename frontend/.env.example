# API Express (puerto del backend, típicamente 3000; el front Next suele ir en 3001)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Cloudflare Turnstile (verificación humana en solicitud pública). En desarrollo, si omites la clave,
# el front usa una clave de prueba que fuerza desafío interactivo (sigue mostrando aviso de «pruebas»).
# En producción define tu site key real del dashboard.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Las fotos se sirven desde {NEXT_PUBLIC_API_URL}/uploads/profiles/...
# La carpeta uploads/ no va en git. Tras clonar, con el backend arriba:
#   npm run sync:profile-photos
# (desde la raíz del repo). Opcional: SYNC_PROFILE_SOURCE_URL si las fotos están en otro host.
